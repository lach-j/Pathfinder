{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@pathfinder/core": [
        "packages/core/src/index.ts"
      ],
      "@pathfinder/state": [
        "packages/state/src/index.ts"
      ]
    }
  },
  "files": [],
  "references": [
    {
      "path": "packages/core"
    },
    {
      "path": "packages/state"
    },
    {
      "path": "packages/cli"
    }
  ]
}
